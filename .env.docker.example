# Copy values into a .env file at the project root (auto-loaded by docker compose)
# Or: docker compose --env-file .env.docker up — if you use a separate env file

JWT_SECRET=replace-with-a-long-random-string

# On the Compose network, host "mongo" is the database service
DATABASE_URL=mongodb://mongo:27017/myphotos

STORAGE_TYPE=local
# For production prefer cloudinary or s3 — see docs/deployment.md
